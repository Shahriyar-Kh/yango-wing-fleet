DJANGO_SECRET_KEY=change-me-to-a-strong-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase PostgreSQL connection URL
# Example: postgresql://postgres:password@db.<project>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yango_wing_fleet
DB_SSL_REQUIRE=True

TIME_ZONE=Asia/Karachi

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:5173

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Yango Wing Fleet <your-gmail@gmail.com>
ADMIN_NOTIFICATION_EMAIL=office@yangowingfleet.pk
